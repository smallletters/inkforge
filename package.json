{
  "name": "inkforge",
  "version": "0.1.0",
  "private": true,
  "description": "灵砚 InkForge — 多Agent小说创作平台",
  "author": "<smallletters@sina.com>",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @inkforge/backend dev\" \"pnpm --filter @inkforge/frontend dev\"",
    "build": "pnpm --filter @inkforge/shared build && pnpm --filter @inkforge/backend build && pnpm --filter @inkforge/frontend build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @inkforge/backend db:generate",
    "db:push": "pnpm --filter @inkforge/backend db:push",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
