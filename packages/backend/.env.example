# 灵砚 InkForge - 后端环境配置示例
# 作者：<smallletters@sina.com>
# 创建日期：2026-04-29

# 应用配置
APP_NAME="灵砚 InkForge"
APP_PORT=3000
APP_HOST="0.0.0.0"
NODE_ENV="development"

# 数据库配置
DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip

# Redis配置
REDIS_URL="redis://localhost:6379"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 日志配置
LOG_LEVEL="info"

# 模型提供商配置 (示例)
# PROVIDERS_OPENAI_API_KEY="sk-..."
# PROVIDERS_ANTHROPIC_API_KEY="sk-ant-..."
# PROVIDERS_GOOGLE_API_KEY="..."
# PROVIDERS_MOONSHOT_API_KEY="sk-..."
